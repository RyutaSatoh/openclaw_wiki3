{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "reason",
    "summary",
    "proposed_pages",
    "link_actions",
    "notes"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "hold_structure",
        "split_page",
        "split_and_link",
        "add_links_only",
        "merge_candidate"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "proposed_pages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slug",
          "title",
          "role",
          "summary",
          "seed_topics",
          "seed_bundle_ids"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "seed_topics": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "seed_bundle_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "link_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "from",
          "to",
          "reason"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "parent-child",
              "related",
              "see-also",
              "merge-review"
            ]
          },
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
